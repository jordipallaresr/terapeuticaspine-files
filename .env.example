# ─────────────────────────────────────────────────────────────────────────────
# Clerk (autenticación). Cópialo a `.env.local` para `pnpm dev` y rellénalo.
# Las claves están en el dashboard de Clerk → API Keys.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# URL de sign-in (deja este valor tal cual salvo que cambies la ruta).
# No hay registro público: el alta se gestiona por invitación/allowlist en Clerk.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in

# ─────────────────────────────────────────────────────────────────────────────
# Prefijo base dentro del bucket R2. Las carpetas se listan bajo este prefijo.
# Cámbialo si reorganizas el bucket. El nombre del binding (IMAGENES_BUCKET) y el
# nombre real del bucket se configuran en wrangler.jsonc, no aquí.
# ─────────────────────────────────────────────────────────────────────────────
BASE_PREFIX=Imagenes/
