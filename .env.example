# ─────────────────────────────────────────────────────────────────────────────
# Clerk (authentication). Copy it to `.env.local` for `pnpm dev` and fill it in.
# The keys are in the Clerk dashboard → API Keys.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Sign-in URL (leave this value as is unless you change the route).
# There is no public sign-up: accounts are managed by invitation/allowlist in Clerk.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in

# ─────────────────────────────────────────────────────────────────────────────
# Base prefix inside the R2 bucket. Folders are listed under this prefix.
# Change it if you reorganize the bucket. The binding name (IMAGENES_BUCKET) and the
# real bucket name are configured in wrangler.jsonc, not here.
# ─────────────────────────────────────────────────────────────────────────────
BASE_PREFIX=Imagenes anteriores/
